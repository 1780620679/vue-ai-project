//这是 TypeScript 的 核心配置文件 ，告诉编译器如何编译项目。

{
  // ========== 编译目标 ==========
  "compilerOptions": {
    // 编译成什么版本的 JavaScript（ES2020 是 2020 年的 JavaScript 标准）
    "target": "ES2020",
    
    // 是否使用 ES2020 的类字段定义方式
    "useDefineForClassFields": true,
    
    // 模块系统：使用最新的模块方式（import/export）
    "module": "ESNext",
    
    // 可以使用的 JavaScript 特性
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    
    // ========== 文件处理 ==========
    // 跳过第三方库的类型检查（加快编译速度）
    "skipLibCheck": true,
    
    // 模块解析方式：使用现代打包工具的方式解析模块
    "moduleResolution": "bundler",
    
    // 允许导入 TypeScript 文件（.ts, .vue）
    "allowImportingTsExtensions": true,
    
    // 允许导入 JSON 文件
    "resolveJsonModule": true,
    
    // 是否将每个文件作为单独的模块（必须开启）
    "isolatedModules": true,
    
    // 不输出编译后的文件（只做类型检查）
    "noEmit": true,
    
    // JSX 处理方式（保留原样，Vue 项目需要）
    "jsx": "preserve",
    
    // ========== 类型检查（严格模式） ==========
    // 开启所有严格类型检查
    "strict": true,
    
    // 检查未使用的局部变量
    "noUnusedLocals": true,
    
    // 检查未使用的函数参数
    "noUnusedParameters": true,
    
    // 检查 switch 语句是否有漏掉的 case
    "noFallthroughCasesInSwitch": true,
    
    // // 忽略弃用警告
    // "ignoreDeprecations": "6.0",
    
    // 路径别名配置
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  
  // 指定要编译的文件目录
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue", "src/main.js"],
  
  // 引用其他配置文件
  "references": [{ "path": "./tsconfig.node.json" }]
}